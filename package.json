{
  "name": "nexoseed",
  "version": "0.3.0",
  "description": "NexoSeed — self-evolving AI OS for Windows",
  "main": "src/index.js",
  "bin": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "build": "pkg src/index.js --targets node18-win-x64 --output dist/NexoSeed.exe --compress GZip"
  },
  "pkg": {
    "assets": [
      "web/**/*"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "dotenv": "^17.4.0",
    "express": "^4.21.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.0.0"
  }
}
